# EcoSync Backend - Environment Variables
# Copiar a .env y completar con tus credenciales

# ============================================
# GitHub OAuth (requerido para autenticación)
# ============================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback

# ============================================
# Google OAuth (requerido para Google Drive)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ============================================
# Reddit API (requerido para clean-reddit)
# ============================================
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ============================================
# Have I Been Pwned (opcional)
# ============================================
HIBP_API_KEY=your_hibp_api_key

# ============================================
# Configuración General
# ============================================
URL_FRONTEND=http://localhost:5173
PORT=4000
SECRET_KEY_BASE=your_secret_key_base_generated_with_mix_phx_gen_secret

# ============================================
# Variables de Inactividad (para análisis de repos)
# ============================================
INACTIVITY_MONTHS=6